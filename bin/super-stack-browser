#!/usr/bin/env bash

set -euo pipefail

TARGET="${SUPER_STACK_AGENT_BROWSER_BIN:-$(command -v agent-browser || true)}"
if [[ -z "${TARGET}" || ! -x "${TARGET}" ]]; then
  PREFIX="$(npm config get prefix 2>/dev/null || true)"
  if [[ -n "${PREFIX}" && -x "${PREFIX}/bin/agent-browser" ]]; then
    TARGET="${PREFIX}/bin/agent-browser"
  fi
fi

SESSION_NAME="${SUPER_STACK_BROWSER_SESSION:-super-stack-browser}"
IDLE_TIMEOUT_MS="${SUPER_STACK_BROWSER_IDLE_TIMEOUT_MS:-900000}"

if [[ ! -x "$TARGET" ]]; then
  printf "[super-stack] 错误：agent-browser 不可用。请先运行 ./scripts/install/install.sh --host all\n" >&2
  exit 1
fi

export AGENT_BROWSER_IDLE_TIMEOUT_MS="${AGENT_BROWSER_IDLE_TIMEOUT_MS:-$IDLE_TIMEOUT_MS}"
exec "$TARGET" --auto-connect --session-name "$SESSION_NAME" "$@"
