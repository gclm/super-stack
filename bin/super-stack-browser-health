#!/usr/bin/env bash

set -euo pipefail

BROWSER_BIN="${HOME}/.super-stack/runtime/bin/super-stack-browser"
SESSION_NAME="${SUPER_STACK_BROWSER_SESSION:-super-stack-browser}"
IDLE_TIMEOUT_MS="${AGENT_BROWSER_IDLE_TIMEOUT_MS:-${SUPER_STACK_BROWSER_IDLE_TIMEOUT_MS:-900000}}"
EXPECTED_AGENT_BROWSER_BASELINE="${SUPER_STACK_EXPECTED_AGENT_BROWSER_BASELINE:-1}"

chrome_total_rss_kb="$(ps -axo rss=,command= | LC_ALL=C awk '/Google Chrome/ && !/awk/ {sum+=$1} END {print sum+0}')"
headless_count="$(ps -axo command= | LC_ALL=C awk '/Google Chrome/ && /--headless(=new)?/ && !/awk/ {count++} END {print count+0}')"
agent_browser_count="$(ps -axo command= | LC_ALL=C awk '/agent-browser/ && !/awk/ {count++} END {print count+0}')"
agent_browser_rss_kb="$(ps -axo rss=,command= | LC_ALL=C awk '/agent-browser/ && !/awk/ {sum+=$1} END {print sum+0}')"
browser_use_count="$(ps -axo command= | LC_ALL=C awk '/browser_use/ && !/awk/ {count++} END {print count+0}')"
chrome_total_rss_mb="$((chrome_total_rss_kb / 1024))"
agent_browser_rss_mb="$((agent_browser_rss_kb / 1024))"
swap_used_mb="$(
  sysctl vm.swapusage 2>/dev/null \
  | sed -n 's/.*used = \([0-9.]*\)M.*/\1/p' \
  | awk '{printf "%.0f", $1+0}'
)"
swap_used_mb="${swap_used_mb:-0}"

if (( agent_browser_count > EXPECTED_AGENT_BROWSER_BASELINE )); then
  agent_browser_residue_count="$((agent_browser_count - EXPECTED_AGENT_BROWSER_BASELINE))"
else
  agent_browser_residue_count=0
fi

browser_use_residue_count="$((browser_use_count + agent_browser_residue_count))"

severity_rank() {
  case "$1" in
    info) printf '1' ;;
    warn) printf '2' ;;
    critical) printf '3' ;;
    *) printf '0' ;;
  esac
}

max_severity() {
  local left="${1:-ok}"
  local right="${2:-ok}"
  if (( $(severity_rank "$right") > $(severity_rank "$left") )); then
    printf '%s' "$right"
  else
    printf '%s' "$left"
  fi
}

emit_alert() {
  local level="$1"
  local message="$2"
  printf '[super-stack][%s] %s\n' "${level}" "${message}" >&2
}

browser_health_level="ok"
system_chrome_level="ok"
swap_pressure_level="ok"

session_info="unavailable"
session_status="missing"
if [[ -x "${BROWSER_BIN}" ]]; then
  if session_output="$("${BROWSER_BIN}" session 2>/dev/null)"; then
    session_info="${session_output}"
    if printf '%s\n' "${session_output}" | grep -Fq "${SESSION_NAME}"; then
      session_status="active"
    else
      session_status="idle"
    fi
  fi
fi

printf 'BROWSER_BIN=%s\n' "${BROWSER_BIN}"
printf 'SESSION_NAME=%s\n' "${SESSION_NAME}"
printf 'SESSION_STATUS=%s\n' "${session_status}"
printf 'IDLE_TIMEOUT_MS=%s\n' "${IDLE_TIMEOUT_MS}"
printf 'HEADLESS_CHROME_COUNT=%s\n' "${headless_count}"
printf 'SYSTEM_CHROME_TOTAL_RSS_MB=%s\n' "${chrome_total_rss_mb}"
printf 'CHROME_TOTAL_RSS_MB=%s\n' "${chrome_total_rss_mb}"
printf 'AGENT_BROWSER_PROCESS_COUNT=%s\n' "${agent_browser_count}"
printf 'AGENT_BROWSER_TOTAL_RSS_MB=%s\n' "${agent_browser_rss_mb}"
printf 'BROWSER_USE_PROCESS_COUNT=%s\n' "${browser_use_count}"
printf 'BROWSER_USE_RESIDUE_COUNT=%s\n' "${browser_use_residue_count}"
printf 'SWAP_USED_MB=%s\n' "${swap_used_mb}"

if [[ "${session_info}" != "unavailable" ]]; then
  printf 'SESSION_INFO=%s\n' "$(printf '%s' "${session_info}" | tr '\n' ' ' | sed 's/  */ /g' | sed 's/ $//')"
fi

if (( browser_use_count > 0 )); then
  browser_health_level="$(max_severity "${browser_health_level}" critical)"
  emit_alert "critical" "检测到 browser_use 相关进程，说明旧链路可能仍在占用浏览器。建议先停止旧链路，再视情况执行 ~/.super-stack/runtime/bin/super-stack-browser-reset。"
fi

if (( agent_browser_residue_count > 0 )); then
  browser_health_level="$(max_severity "${browser_health_level}" warn)"
  emit_alert "warn" "检测到 ${agent_browser_residue_count} 个额外 agent-browser 进程。正常基线允许 1 个常驻守护进程；仅在出现额外副本时才建议执行 ~/.super-stack/runtime/bin/super-stack-browser-reset。"
fi

if (( headless_count > 1 )); then
  browser_health_level="$(max_severity "${browser_health_level}" warn)"
  emit_alert "warn" "检测到多个 headless Chrome。若当前并未并发执行浏览器任务，建议运行 ~/.super-stack/runtime/bin/super-stack-browser-reset。"
fi

if (( chrome_total_rss_mb >= 6144 )); then
  system_chrome_level="critical"
  emit_alert "critical" "系统级 Chrome 总内存已超过 6GB。更像是整机标签页或扩展负载过高，不等同于 super-stack 浏览器链路异常；优先回收标签页，如同时伴随高 swap，可考虑重启电脑。"
elif (( chrome_total_rss_mb >= 4096 )); then
  system_chrome_level="warn"
  emit_alert "warn" "系统级 Chrome 总内存已超过 4GB。这通常反映整机标签页或扩展占用，不等同于 super-stack 浏览器链路异常；优先关闭高占用标签页。"
elif (( chrome_total_rss_mb >= 2048 )); then
  system_chrome_level="info"
  emit_alert "info" "系统级 Chrome 总内存已超过 2GB，建议留意标签页和扩展数量。"
fi

if (( swap_used_mb >= 3072 )); then
  swap_pressure_level="critical"
  emit_alert "critical" "系统 swap 已超过 3GB，说明整机内存压力明显；若关闭重应用后仍不回落，建议重启电脑。"
elif (( swap_used_mb >= 2048 )); then
  swap_pressure_level="warn"
  emit_alert "warn" "系统 swap 已超过 2GB，近期可能出现切应用变慢或浏览器卡顿。"
elif (( swap_used_mb >= 1024 )); then
  swap_pressure_level="info"
  emit_alert "info" "系统 swap 已超过 1GB，机器近期有过一定内存压力。"
fi

overall_health_level="$(max_severity "${browser_health_level}" "${system_chrome_level}")"
overall_health_level="$(max_severity "${overall_health_level}" "${swap_pressure_level}")"

printf 'BROWSER_HEALTH_LEVEL=%s\n' "${browser_health_level}"
printf 'SYSTEM_CHROME_LEVEL=%s\n' "${system_chrome_level}"
printf 'SWAP_PRESSURE_LEVEL=%s\n' "${swap_pressure_level}"
printf 'OVERALL_HEALTH_LEVEL=%s\n' "${overall_health_level}"
