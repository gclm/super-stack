{
  "blocks": {
    "codex_agents": {
      "target_format": "toml",
      "begin_marker": "# BEGIN SUPER-STACK AGENTS",
      "end_marker": "# END SUPER-STACK AGENTS",
      "content": {
        "features": {
          "multi_agent": true
        },
        "agents": {
          "max_threads": 6,
          "max_depth": 1
        },
        "agent_defs": [
          {
            "id": "super_stack_explorer",
            "description": "Read-only codebase exploration and evidence gathering.",
            "config_file": "agents/super-stack-explorer.toml"
          },
          {
            "id": "super_stack_reviewer",
            "description": "Risk-focused review for correctness, regressions, and missing tests.",
            "config_file": "agents/super-stack-reviewer.toml"
          },
          {
            "id": "super_stack_planner",
            "description": "Task decomposition and implementation planning.",
            "config_file": "agents/super-stack-planner.toml"
          },
          {
            "id": "super_stack_builder",
            "description": "Bounded implementation with minimal diffs and explicit verification.",
            "config_file": "agents/super-stack-builder.toml"
          }
        ]
      },
      "target_file_template": "{home}/.codex/config.toml",
      "ownership": "managed_block",
      "verify": {
        "contains": [
          "multi_agent = true"
        ],
        "agent_config_files_field": "config_files",
        "markers": [
          "# BEGIN SUPER-STACK AGENTS",
          "# END SUPER-STACK AGENTS"
        ],
        "registered_entries": [
          "config_file = \"agents/super-stack-explorer.toml\"",
          "config_file = \"agents/super-stack-reviewer.toml\"",
          "config_file = \"agents/super-stack-planner.toml\"",
          "config_file = \"agents/super-stack-builder.toml\""
        ]
      },
      "managed_files": [
        "{home}/.codex/agents/super-stack-explorer.toml",
        "{home}/.codex/agents/super-stack-reviewer.toml",
        "{home}/.codex/agents/super-stack-planner.toml",
        "{home}/.codex/agents/super-stack-builder.toml"
      ]
    },
    "codex_hooks": {
      "target_format": "toml",
      "begin_marker": "# BEGIN SUPER-STACK HOOKS",
      "end_marker": "# END SUPER-STACK HOOKS",
      "content": {
        "include_hooks_table": true,
        "hooks": [
          {
            "event": "session_start",
            "command_template": "python3 \"{runtime_root}/.codex/hooks/super_stack_state.py\""
          },
          {
            "event": "pre_tool_use",
            "command_template": "python3 \"{runtime_root}/scripts/hooks/readonly_command_guard.py\" --host codex"
          },
          {
            "event": "stop",
            "command_template": "python3 \"{runtime_root}/.codex/hooks/super_stack_state.py\""
          }
        ]
      },
      "target_file_template": "{home}/.codex/config.toml",
      "ownership": "managed_block",
      "verify": {
        "commands_field": "commands",
        "markers": [
          "# BEGIN SUPER-STACK HOOKS",
          "# END SUPER-STACK HOOKS"
        ]
      }
    },
    "claude_hooks": {
      "target_format": "json",
      "content": {
        "hooks": {
          "SessionStart": [
            {
              "matcher": "",
              "hooks": [
                {
                  "type": "command",
                  "command": "if [ -f .planning/STATE.md ]; then echo '[super-stack] resuming from .planning/STATE.md'; head -20 .planning/STATE.md; fi"
                }
              ]
            }
          ],
          "PreToolUse": [
            {
              "matcher": "Bash",
              "hooks": [
                {
                  "type": "command",
                  "command_template": "python3 \"{runtime_root}/scripts/hooks/readonly_command_guard.py\" --host claude"
                }
              ]
            }
          ],
          "Stop": [
            {
              "matcher": "",
              "hooks": [
                {
                  "type": "command",
                  "command": "if [ -f .planning/STATE.md ]; then echo '[super-stack] remember to leave STATE.md current'; fi"
                }
              ]
            }
          ]
        }
      },
      "target_file_template": "{home}/.claude/settings.json",
      "ownership": "managed_block",
      "verify": {
        "commands_field": "commands",
        "contains": [
          "\"hooks\"",
          "\"PreToolUse\""
        ]
      }
    }
  }
}
