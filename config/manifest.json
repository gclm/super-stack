{
  "manifest_version": 1,
  "mcp": {
    "servers": {
      "chrome-devtools-mcp": {
        "command_env": "CHROME_DEVTOOLS_MCP_BIN",
        "command_fixed_template": "{home}/.local/share/fnm/node-versions/v24.14.0/installation/bin/chrome-devtools-mcp",
        "args": [
          "--autoConnect",
          "-y"
        ],
        "enabled": true
      },
      "openspace": {
        "command_env": "OPENSPACE_MCP_BIN",
        "command_fixed_template": "{home}/.super-stack/openspace/.conda/bin/openspace-mcp",
        "env": {
          "OPENSPACE_HOST_SKILL_DIRS": "{home}/.agents/skills",
          "OPENSPACE_WORKSPACE": "{home}/.super-stack/openspace"
        },
        "enabled": true
      }
    }
  },
  "managed_blocks": {
    "codex_agents": {
      "target_format": "toml",
      "begin_marker": "# BEGIN SUPER-STACK AGENTS",
      "end_marker": "# END SUPER-STACK AGENTS",
      "content": {
        "features": {
          "multi_agent": true
        },
        "agents": {
          "max_threads": 6,
          "max_depth": 1
        },
        "agent_defs": [
          {
            "id": "super_stack_explorer",
            "description": "Read-only codebase exploration and evidence gathering.",
            "config_file": "agents/super-stack-explorer.toml"
          },
          {
            "id": "super_stack_reviewer",
            "description": "Risk-focused review for correctness, regressions, and missing tests.",
            "config_file": "agents/super-stack-reviewer.toml"
          },
          {
            "id": "super_stack_planner",
            "description": "Task decomposition and implementation planning.",
            "config_file": "agents/super-stack-planner.toml"
          },
          {
            "id": "super_stack_builder",
            "description": "Bounded implementation with minimal diffs and explicit verification.",
            "config_file": "agents/super-stack-builder.toml"
          }
        ]
      },
      "target_file_template": "{home}/.codex/config.toml",
      "ownership": "managed_block",
      "verify": {
        "contains": [
          "multi_agent = true"
        ],
        "agent_config_files_field": "config_files",
        "markers": [
          "# BEGIN SUPER-STACK AGENTS",
          "# END SUPER-STACK AGENTS"
        ],
        "registered_entries": [
          "config_file = \"agents/super-stack-explorer.toml\"",
          "config_file = \"agents/super-stack-reviewer.toml\"",
          "config_file = \"agents/super-stack-planner.toml\"",
          "config_file = \"agents/super-stack-builder.toml\""
        ]
      },
      "managed_files": [
        "{home}/.codex/agents/super-stack-explorer.toml",
        "{home}/.codex/agents/super-stack-reviewer.toml",
        "{home}/.codex/agents/super-stack-planner.toml",
        "{home}/.codex/agents/super-stack-builder.toml"
      ],
      "kind": "agents"
    },
    "codex_hooks": {
      "target_format": "toml",
      "begin_marker": "# BEGIN SUPER-STACK HOOKS",
      "end_marker": "# END SUPER-STACK HOOKS",
      "content": {
        "include_hooks_table": true,
        "hooks": [
          {
            "event": "session_start",
            "command_template": "python3 \"{runtime_root}/.codex/hooks/super_stack_state.py\""
          },
          {
            "event": "pre_tool_use",
            "command_template": "python3 \"{runtime_root}/scripts/hooks/readonly_command_guard.py\" --host codex"
          },
          {
            "event": "stop",
            "command_template": "python3 \"{runtime_root}/.codex/hooks/super_stack_state.py\""
          }
        ]
      },
      "target_file_template": "{home}/.codex/config.toml",
      "ownership": "managed_block",
      "verify": {
        "commands_field": "commands",
        "markers": [
          "# BEGIN SUPER-STACK HOOKS",
          "# END SUPER-STACK HOOKS"
        ]
      },
      "kind": "hooks"
    },
    "codex_mcp": {
      "target_format": "toml",
      "begin_marker": "# BEGIN SUPER-STACK CODEX MCP",
      "end_marker": "# END SUPER-STACK CODEX MCP",
      "content": {
        "servers": [
          "chrome-devtools-mcp",
          "openspace"
        ]
      },
      "target_file_template": "{home}/.codex/config.toml",
      "ownership": "managed_block",
      "verify": {
        "include_resolved_server_markers": true,
        "contains": [
          "enabled = true",
          "--autoConnect"
        ],
        "markers": [
          "# BEGIN SUPER-STACK CODEX MCP",
          "# END SUPER-STACK CODEX MCP"
        ]
      },
      "kind": "mcp"
    },
    "claude_mcp": {
      "target_format": "json",
      "content": {
        "servers": [
          "chrome-devtools-mcp"
        ]
      },
      "target_file_template": "{home}/.claude/settings.json",
      "ownership": "managed_block",
      "verify": {
        "contains": [
          "\"mcpServers\"",
          "\"chrome-devtools-mcp\"",
          "\"--autoConnect\""
        ]
      },
      "kind": "mcp"
    },
    "claude_hooks": {
      "target_format": "json",
      "content": {
        "hooks": {
          "SessionStart": [
            {
              "matcher": "",
              "hooks": [
                {
                  "type": "command",
                  "command": "if [ -f harness/state.md ]; then echo '[super-stack] resuming from harness/state.md'; head -20 harness/state.md; fi"
                }
              ]
            }
          ],
          "PreToolUse": [
            {
              "matcher": "Bash",
              "hooks": [
                {
                  "type": "command",
                  "command_template": "python3 \"{runtime_root}/scripts/hooks/readonly_command_guard.py\" --host claude"
                }
              ]
            }
          ],
          "Stop": [
            {
              "matcher": "",
              "hooks": [
                {
                  "type": "command",
                  "command": "if [ -f harness/state.md ]; then echo '[super-stack] remember to leave harness/state.md current'; fi"
                }
              ]
            }
          ]
        }
      },
      "target_file_template": "{home}/.claude/settings.json",
      "ownership": "managed_block",
      "verify": {
        "commands_field": "commands",
        "contains": [
          "\"hooks\"",
          "\"PreToolUse\""
        ]
      },
      "kind": "hooks"
    }
  },
  "skill_validation": {
    "ignore_warnings": [],
    "path_semantics": [
      {
        "repo_path": "scripts/check/check-browser-capability.sh",
        "runtime_path": "~/.super-stack/runtime/scripts/check/check-browser-capability.sh",
        "preferred_form": "runtime",
        "reason": "browser capability probe is mirrored into runtime and skills should use the managed runtime path when referring to host-side probing."
      },
      {
        "repo_path": "scripts/check/check-codex-runtime.sh",
        "runtime_path": "~/.super-stack/runtime/scripts/check/check-codex-runtime.sh",
        "preferred_form": "runtime",
        "reason": "Codex runtime diagnosis is part of the managed runtime check subset."
      },
      {
        "repo_path": "scripts/check/validate-skills.py",
        "runtime_path": "~/.super-stack/runtime/scripts/check/validate-skills.py",
        "preferred_form": "source",
        "reason": "skill maintenance still validates repository truth from the source repo even though the helper is mirrored for runtime diagnostics."
      },
      {
        "repo_path": "scripts/workflow/init-generated-project.sh",
        "runtime_path": "~/.super-stack/runtime/scripts/workflow/init-generated-project.sh",
        "preferred_form": "runtime",
        "reason": "bootstrap skills should point at the managed runtime workflow entrypoint rather than assume a source checkout path."
      },
      {
        "repo_path": "scripts/workflow/init-harness-task.sh",
        "runtime_path": "~/.super-stack/runtime/scripts/workflow/init-harness-task.sh",
        "preferred_form": "runtime",
        "reason": "task pack bootstrap should use the managed runtime workflow entrypoint when surfaced in skills."
      }
    ]
  }
}
